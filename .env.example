# Database
DB_USER=postgres
DB_NAME=payments_db
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432

# API
API_KEY=secret-api-key
API_HOST=0.0.0.0
API_PORT=8000

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
PAYMENTS_QUEUE=payments.new
PAYMENTS_DLQ=payments.new.dlq
PAYMENTS_EXCHANGE=payments.exchange
PAYMENTS_ROUTING_KEY=payment.created

# Outbox Publisher
OUTBOX_POLL_INTERVAL=1.0
OUTBOX_BATCH_SIZE=100

# Payment processing
PAYMENT_MIN_DELAY=2.0
PAYMENT_MAX_DELAY=5.0
PAYMENT_SUCCESS_RATE=0.9

# Webhook
WEBHOOK_TIMEOUT=10.0
WEBHOOK_MAX_RETRIES=3
